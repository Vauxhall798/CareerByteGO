{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "careerbytecode.html", "use": "@vercel/static" },
    { "src": "static/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/$", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}

